{
  "name": "react-typescript-keystone-template",
  "version": "0.1.14",
  "author": {
    "email": "dominic@dominic-classen.de",
    "name": "Dominic Claßen",
    "url": "https://majesnix.dev"
  },
  "private": true,
  "packageManager": "pnpm@10.11.0",
  "dependencies": {
    "ky": "^2.0.2",
    "mobx": "^6.15.3",
    "mobx-keystone": "^1.21.0",
    "mobx-react-lite": "^4.1.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router": "^7.15.0",
    "react-scripts": "5.0.1",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "react-scripts start",
    "start:noBrowser": "cross-env BROWSER=none react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test --transformIgnorePatterns \"node_modules/(?!ky)/\"",
    "eject": "react-scripts eject",
    "cypress:open": "cypress open",
    "e2e": "start-server-and-test 'pnpm start:noBrowser' http://localhost:3000 'pnpm cypress:open'",
    "e2e:run:chrome": "cypress run --browser chrome",
    "e2e:ci": "start-server-and-test 'pnpm start:noBrowser' http://localhost:3000 'pnpm e2e:run:chrome'"
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@testing-library/cypress": "^10.1.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-router": "^5.1.20",
    "@types/react-router-dom": "^5.3.3",
    "caniuse-lite": "^1.0.30001792",
    "cross-env": "^10.1.0",
    "cypress": "^15.15.0",
    "miragejs": "^0.1.48",
    "start-server-and-test": "^3.0.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "core-js",
      "core-js-pure",
      "cypress"
    ],
    "overrides": {
      "open": "11.0.0"
    }
  }
}
